{
  "name": "ismo-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build && pnpm create-users",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "seed": "ts-node prisma/seeder.ts",
    "create-admin": "ts-node prisma/create-admin.ts",
    "create-users": "ts-node prisma/create-users.ts",
    "upload-profile": "ts-node scripts/upload-profile-image.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint:fix": "eslint . \"src/**/*.ts\" --fix",
    "test": "jest",
    "pre-commit": "pnpm type-check && pnpm lint:fix && pnpm format",
    "test:watch": "jest --watch",
    "generate": "npx prisma generate",
    "git:clean": "git branch | grep -v main | grep -v staging | xargs git branch -D && git fetch -p",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org poyesis --project ismo-backend dist && sentry-cli sourcemaps upload --org poyesis --project ismo-backend dist"
  },
  "dependencies": {
    "@anatine/zod-nestjs": "^2.0.9",
    "@anatine/zod-openapi": "^2.0.1",
    "@faker-js/faker": "^9.0.3",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^5.20.0",
    "@sentry/cli": "^2.42.2",
    "@sentry/nestjs": "^9.2.0",
    "argon2": "^0.41.1",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.7.9",
    "body-parser": "^1.20.3",
    "class-transformer": "^0.5.1",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "express": "^4.21.2",
    "html-to-text": "^9.0.5",
    "lodash": "^4.17.21",
    "openapi3-ts": "^4.1.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.15.2",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "sib-api-v3-typescript": "^2.2.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@swc/cli": "^0.4.0",
    "@swc/core": "^1.10.1",
    "@types/body-parser": "^1.19.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.17",
    "@types/html-to-text": "^9.0.4",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.13.7",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "prisma": "^5.20.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
